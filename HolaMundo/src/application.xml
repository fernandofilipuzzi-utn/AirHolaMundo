<?xml version="1.0" encoding="UTF-8"?>
<application 
    xmlns="http://ns.adobe.com/air/application/33.1"
    xmlns:android="http://ns.adobe.com/air/application/android"
    xmlns:ios="http://ns.adobe.com/air/application/ios">
    
    <!-- Identificadores básicos de la aplicación -->
    <id>com.example.holaair</id>
    <versionNumber>1.0.0</versionNumber>
    <filename>HolaAIR</filename>
    
    <!-- Nombre y descripción -->
    <name>Hola AIR</name>
    <description>Aplicación mínima de prueba con Adobe AIR y Apache Flex</description>
    
    <!-- Punto de entrada (archivo SWF compilado) -->
    <initialWindow>
        <content>Main.swf</content>
        <visible>true</visible>
        <width>400</width>
        <height>300</height>
        <minSize>400 300</minSize>
        <title>Hola AIR - Aplicación de Escritorio</title>
    </initialWindow>
    
    <!-- Idiomas soportados -->
    <supportedLanguages>es</supportedLanguages>
    
</application>
